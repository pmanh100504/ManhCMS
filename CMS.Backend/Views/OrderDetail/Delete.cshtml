@model CMS.Data.Entities.OrderDetail

@{
    ViewData["Title"] = "Xóa chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
    decimal subtotal = Model.Quantity * Model.UnitPrice;
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">XÓA CHI TIẾT ĐƠN HÀNG</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h5><i class="bi bi-exclamation-triangle"></i> Cảnh báo!</h5>
                Bạn có chắc chắn muốn xóa mặt hàng này khỏi đơn hàng không?
            </div>

            <dl class="row mt-3">
                <dt class="col-sm-4 font-weight-bold">Mã đơn hàng:</dt>
                <dd class="col-sm-8">#@Model.OrderId</dd>

                <dt class="col-sm-4 font-weight-bold">Sản phẩm:</dt>
                <dd class="col-sm-8">@(Model.Product?.Name ?? "N/A")</dd>

                <dt class="col-sm-4 font-weight-bold">Đơn giá:</dt>
                <dd class="col-sm-8">@Model.UnitPrice.ToString("N0") VNĐ</dd>

                <dt class="col-sm-4 font-weight-bold">Số lượng:</dt>
                <dd class="col-sm-8">@Model.Quantity</dd>

                <dt class="col-sm-4 font-weight-bold">Thành tiền:</dt>
                <dd class="col-sm-8 text-danger font-weight-bold">@subtotal.ToString("N0") VNĐ</dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Xác nhận xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
