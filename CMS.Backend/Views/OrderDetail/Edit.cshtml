@model CMS.Data.Entities.OrderDetail

@{
    ViewData["Title"] = "Cập nhật chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">CẬP NHẬT CHI TIẾT ĐƠN HÀNG</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="OrderId" class="form-label font-weight-bold">Đơn hàng <span class="text-danger">*</span></label>
                    <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId" required></select>
                    <span asp-validation-for="OrderId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductId" class="form-label font-weight-bold">Sản phẩm <span class="text-danger">*</span></label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId" required></select>
                    <span asp-validation-for="ProductId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label font-weight-bold">Số lượng <span class="text-danger">*</span></label>
                    <input asp-for="Quantity" type="number" min="1" class="form-control" required />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UnitPrice" class="form-label font-weight-bold">Đơn giá <span class="text-danger">*</span></label>
                    <input asp-for="UnitPrice" type="number" min="0" step="0.01" class="form-control" required />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save"></i> Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
