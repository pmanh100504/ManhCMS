@model IEnumerable<CMS.Data.Entities.OrderDetail>

@{
    ViewData["Title"] = "Chi tiết tất cả đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">CHI TIẾT ĐƠN HÀNG</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm sản phẩm vào đơn hàng
        </a>
    </div>
    
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Sản phẩm</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                            <th style="width: 150px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                decimal subtotal = item.Quantity * item.UnitPrice;
                                <tr>
                                    <td>
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId" class="font-weight-bold">
                                            #@item.OrderId
                                        </a>
                                    </td>
                                    <td>
                                        @(item.Order?.Customer?.FullName ?? "N/A")
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="img-thumbnail me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                            }
                                            <span>@item.Product?.Name</span>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        @item.UnitPrice.ToString("N0") VNĐ
                                    </td>
                                    <td class="text-center">
                                        @item.Quantity
                                    </td>
                                    <td class="text-end text-danger font-weight-bold">
                                        @subtotal.ToString("N0") VNĐ
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Xóa">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    Chưa có chi tiết đơn hàng nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
