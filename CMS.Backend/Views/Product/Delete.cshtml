@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">XÁC NHẬN XÓA SẢN PHẨM</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h5><i class="bi bi-exclamation-triangle"></i> Bạn có chắc chắn muốn xóa sản phẩm này? Hành động này không thể hoàn tác.</h5>
            </div>
            
            <div class="row mb-4">
                <div class="col-md-3 text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border" style="max-height: 150px; object-fit: cover;" />
                    }
                </div>
                <div class="col-md-9">
                    <h3>@Model.Name</h3>
                    <p class="mb-1"><strong>Danh mục:</strong> @Model.CategoryProduct?.Name</p>
                    <p class="mb-1"><strong>Giá bán:</strong> @Model.Price.ToString("N0") VNĐ</p>
                    <p class="mb-1"><strong>Hiển thị:</strong> @(Model.Published ? "Có" : "Không")</p>
                </div>
            </div>
            
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Xóa sản phẩm</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
            </form>
        </div>
    </div>
</div>
