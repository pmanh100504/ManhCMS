@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">DANH SÁCH SẢN PHẨM</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
        </a>
    </div>
    
    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100 d-flex flex-column">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light border text-center text-muted card-img-top d-flex align-items-center justify-content-center" style="height: 200px;">
                                <span style="font-size: 14px;">Không có hình ảnh</span>
                            </div>
                        }
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge bg-info text-dark">@item.CategoryProduct?.Name</span>
                                    @if (item.Published)
                                    {
                                        <span class="badge bg-success">Có hiển thị</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Không hiển thị</span>
                                    }
                                </div>
                                <h5 class="card-title text-primary">@item.Name</h5>
                                <p class="card-text text-truncate text-muted">@item.Description</p>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-danger font-weight-bold" style="font-size: 1.1rem; font-weight: bold;">@item.Price.ToString("N0") VNĐ</span>
                                    <span class="text-muted small">Tồn kho: @item.StockQuantity</span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-2 border-top pt-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Chưa có sản phẩm nào được tạo.</p>
            </div>
        }
    </div>
</div>
