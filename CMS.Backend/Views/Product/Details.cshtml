@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">CHI TIẾT SẢN PHẨM</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center mb-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 300px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center rounded border" style="height: 200px;">
                            <span class="text-muted">Không có ảnh</span>
                        </div>
                    }
                </div>
                <div class="col-md-8">
                    <h2 class="text-primary mb-3">@Model.Name</h2>
                    
                    <table class="table table-bordered table-striped">
                        <tr>
                            <th style="width: 30%">Mã sản phẩm</th>
                            <td>@Model.Id</td>
                        </tr>
                        <tr>
                            <th>Danh mục</th>
                            <td><span class="badge bg-info text-dark">@Model.Category?.Name</span></td>
                        </tr>
                        <tr>
                            <th>Giá bán</th>
                            <td class="text-danger font-weight-bold">@Model.Price.ToString("N0") VNĐ</td>
                        </tr>
                        <tr>
                            <th>Tồn kho</th>
                            <td>@Model.StockQuantity</td>
                        </tr>
                        <tr>
                            <th>Hiển thị</th>
                            <td>@(Model.Published ? "Có" : "Không")</td>
                        </tr>
                        <tr>
                            <th>Mô tả</th>
                            <td>@Model.Description</td>
                        </tr>
                    </table>
                </div>
            </div>
            
            <hr />
            <div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Chỉnh sửa</a>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>
