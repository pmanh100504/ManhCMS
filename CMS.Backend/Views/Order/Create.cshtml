@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Tạo đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">TẠO ĐƠN HÀNG MỚI</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CustomerId" class="form-label font-weight-bold">Khách hàng <span class="text-danger">*</span></label>
                    <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerId" required>
                        <option value="">-- Chọn khách hàng --</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="OrderDate" class="form-label font-weight-bold">Ngày đặt hàng <span class="text-danger">*</span></label>
                    <input asp-for="OrderDate" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                    <span asp-validation-for="OrderDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label font-weight-bold">Trạng thái <span class="text-danger">*</span></label>
                    <select asp-for="Status" class="form-select" required>
                        <option value="0">Chờ duyệt</option>
                        <option value="1">Đang giao</option>
                        <option value="2">Đã xong</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label font-weight-bold">Ghi chú</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Nhập ghi chú đơn hàng"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Tạo đơn
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
