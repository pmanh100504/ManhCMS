@model IEnumerable<CMS.Data.Entities.Order>

@{
    ViewData["Title"] = "Danh sách đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">DANH SÁCH ĐƠN HÀNG</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Tạo đơn hàng mới
        </a>
    </div>
    
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt hàng</th>
                            <th>Trạng thái</th>
                            <th>Ghi chú</th>
                            <th style="width: 200px;" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>#@item.Id</strong>
                                    </td>
                                    <td>
                                        @(item.Customer?.FullName ?? "Chưa có")
                                    </td>
                                    <td>
                                        @item.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td>
                                        @if (item.Status == 0)
                                        {
                                            <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                        }
                                        else if (item.Status == 1)
                                        {
                                            <span class="badge bg-info text-dark">Đang giao</span>
                                        }
                                        else if (item.Status == 2)
                                        {
                                            <span class="badge bg-success">Đã xong</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Không rõ (@item.Status)</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted text-truncate d-inline-block" style="max-width: 200px;">
                                            @(string.IsNullOrEmpty(item.Notes) ? "Không có" : item.Notes)
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm" title="Chi tiết">
                                            <i class="bi bi-eye"></i> Xem
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Sửa">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Xóa">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    Chưa có đơn hàng nào được tạo.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
