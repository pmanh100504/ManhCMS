@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
    decimal grandTotal = Model.OrderDetails?.Sum(od => od.Quantity * od.UnitPrice) ?? 0;
}

<div class="container mt-4">
    <div class="card shadow mb-4">
        <div class="card-header bg-info text-dark d-flex justify-content-between align-items-center">
            <h4 class="mb-0">ĐƠN HÀNG #@Model.Id</h4>
            <span class="badge bg-light text-dark">Ngày đặt: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <h5 class="border-bottom pb-2">Thông tin khách hàng</h5>
                    <dl class="row">
                        <dt class="col-sm-4 font-weight-bold">Họ và tên:</dt>
                        <dd class="col-sm-8">@(Model.Customer?.FullName ?? "N/A")</dd>

                        <dt class="col-sm-4 font-weight-bold">Email:</dt>
                        <dd class="col-sm-8">@(Model.Customer?.Email ?? "N/A")</dd>

                        <dt class="col-sm-4 font-weight-bold">Số điện thoại:</dt>
                        <dd class="col-sm-8">@(Model.Customer?.Phone ?? "Chưa cập nhật")</dd>

                        <dt class="col-sm-4 font-weight-bold">Địa chỉ:</dt>
                        <dd class="col-sm-8">@(Model.Customer?.Address ?? "Chưa cập nhật")</dd>
                    </dl>
                </div>
                <div class="col-md-6 mb-3">
                    <h5 class="border-bottom pb-2">Trạng thái đơn hàng</h5>
                    <dl class="row">
                        <dt class="col-sm-4 font-weight-bold">Trạng thái:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Status == 0)
                            {
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                            }
                            else if (Model.Status == 1)
                            {
                                <span class="badge bg-info text-dark">Đang giao</span>
                            }
                            else if (Model.Status == 2)
                            {
                                <span class="badge bg-success">Đã xong</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Không rõ (@Model.Status)</span>
                            }
                        </dd>

                        <dt class="col-sm-4 font-weight-bold">Ghi chú:</dt>
                        <dd class="col-sm-8 text-muted">@(string.IsNullOrEmpty(Model.Notes) ? "Không có ghi chú" : Model.Notes)</dd>
                    </dl>
                </div>
            </div>

            <h5 class="border-bottom pb-2 mt-4">Sản phẩm đã đặt</h5>
            <div class="table-responsive">
                <table class="table table-hover table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-end" style="width: 150px;">Đơn giá</th>
                            <th class="text-center" style="width: 100px;">Số lượng</th>
                            <th class="text-end" style="width: 180px;">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                        {
                            foreach (var detail in Model.OrderDetails)
                            {
                                decimal subtotal = detail.Quantity * detail.UnitPrice;
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(detail.Product?.ImageUrl))
                                            {
                                                <img src="@detail.Product.ImageUrl" alt="@detail.Product.Name" class="img-thumbnail me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div class="bg-light border text-center text-muted me-3" style="width: 50px; height: 50px; line-height: 50px; font-size: 10px;">No img</div>
                                            }
                                            <div>
                                                <strong>@detail.Product?.Name</strong>
                                                <br />
                                                <small class="text-muted">ID sản phẩm: @detail.ProductId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">@detail.UnitPrice.ToString("N0") VNĐ</td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end text-danger font-weight-bold">@subtotal.ToString("N0") VNĐ</td>
                                </tr>
                            }
                            <tr class="table-light">
                                <td colspan="3" class="text-end font-weight-bold"><strong>TỔNG TIỀN ĐƠN HÀNG:</strong></td>
                                <td class="text-end text-danger font-weight-bold" style="font-size: 1.2rem;">
                                    <strong>@grandTotal.ToString("N0") VNĐ</strong>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    Không có sản phẩm nào trong chi tiết đơn hàng này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Chỉnh sửa
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
