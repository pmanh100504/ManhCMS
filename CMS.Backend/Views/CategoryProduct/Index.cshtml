@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Danh mục Sản phẩm";
}
@model IEnumerable<CMS.Data.Entities.CategoryProduct>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary font-weight-bold m-0">
        <i class="bi bi-tags-fill"></i> QUẢN LÝ DANH MỤC SẢN PHẨM
    </h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-lg"></i> Thêm danh mục mới
    </a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-lg mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mr-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead>
                    <tr>
                        <th class="px-4 py-3" style="width: 80px">ID</th>
                        <th class="px-4 py-3">Tên Danh Mục</th>
                        <th class="px-4 py-3">Mô tả chi tiết</th>
                        <th class="px-4 py-3 text-end" style="width: 200px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-inbox-fill display-4 d-block mb-3"></i>
                                Chưa có danh mục sản phẩm nào trong cơ sở dữ liệu.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 font-weight-bold text-secondary">@item.Id</td>
                                <td class="px-4 py-3 font-weight-bold text-dark">@item.Name</td>
                                <td class="px-4 py-3 text-secondary">@(string.IsNullOrEmpty(item.Description) ? "Không có mô tả" : item.Description)</td>
                                <td class="px-4 py-3 text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" 
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này? Điều này không thể hoàn tác nếu được thực hiện.')">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
