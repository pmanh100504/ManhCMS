@model CMS.Data.Entities.Customer

@{
    ViewData["Title"] = "Xóa khách hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">XÓA KHÁCH HÀNG</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h5><i class="bi bi-exclamation-triangle"></i> Cảnh báo!</h5>
                Bạn có chắc chắn muốn xóa khách hàng này không? Hành động này không thể hoàn tác.
            </div>

            <dl class="row mt-3">
                <dt class="col-sm-4 font-weight-bold">Mã khách hàng:</dt>
                <dd class="col-sm-8">@Model.Id</dd>

                <dt class="col-sm-4 font-weight-bold">Họ và tên:</dt>
                <dd class="col-sm-8">@Model.FullName</dd>

                <dt class="col-sm-4 font-weight-bold">Email:</dt>
                <dd class="col-sm-8">@Model.Email</dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Xác nhận xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
